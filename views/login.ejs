<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SECURE ACCESS | HemoVault</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;600;700&display=swap" rel="stylesheet">
    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        :root {
            --bg-dark: #0b0f1a;
            --glass-bg: rgba(30, 41, 59, 0.4);
            --accent-blue: #00d2ff;
            --accent-purple: #9d50bb;
            --accent-red: #ff416c;
        }

        body {
            background: radial-gradient(circle at center, #1b263b 0%, #0b0f1a 100%);
            color: #f8fafc;
            font-family: 'Poppins', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: hidden;
        }

        .login-container {
            width: 100%;
            max-width: 450px;
            padding: 20px;
            position: relative;
        }

        /* Decorative Background Glows */
        .login-container::before {
            content: '';
            position: absolute;
            top: -50px;
            left: -50px;
            width: 150px;
            height: 150px;
            background: var(--accent-blue);
            filter: blur(80px);
            opacity: 0.2;
            z-index: -1;
        }

        .login-container::after {
            content: '';
            position: absolute;
            bottom: -50px;
            right: -50px;
            width: 150px;
            height: 150px;
            background: var(--accent-purple);
            filter: blur(80px);
            opacity: 0.2;
            z-index: -1;
        }

        .glass-card {
            background: var(--glass-bg);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255, 255, 255, 0.08);
            border-radius: 24px;
            padding: 3rem;
            box-shadow: 0 20px 50px rgba(0, 0, 0, 0.5);
        }

        .brand-logo {
            width: 60px;
            height: 60px;
            background: rgba(255, 65, 108, 0.1);
            border: 1px solid rgba(255, 65, 108, 0.5);
            border-radius: 16px;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 1.5rem;
            font-size: 1.5rem;
            color: var(--accent-red);
            box-shadow: 0 0 15px rgba(255, 65, 108, 0.3);
        }

        .form-label {
            font-size: 0.8rem;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: #94a3b8;
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .form-control {
            background: rgba(255, 255, 255, 0.05) !important;
            border: 1px solid rgba(255, 255, 255, 0.1) !important;
            color: #fff !important;
            border-radius: 12px;
            padding: 12px 16px;
            transition: all 0.3s ease;
        }

        .form-control:focus {
            background: rgba(255, 255, 255, 0.08) !important;
            border-color: var(--accent-blue) !important;
            box-shadow: 0 0 15px rgba(0, 210, 255, 0.2) !important;
            outline: none;
        }

        .btn-login {
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
            border: none;
            border-radius: 12px;
            padding: 16px;
            font-weight: 700;
            letter-spacing: 1.5px;
            margin-top: 1.5rem;
            transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            color: white;
            width: 100%;
            text-transform: uppercase;
            box-shadow: 0 4px 15px rgba(0, 0, 0, 0.3);
            position: relative;
            overflow: hidden;
        }

        .btn-login:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(157, 80, 187, 0.5);
            letter-spacing: 2.5px;
        }

        .btn-login:active {
            transform: translateY(-1px);
        }

        .btn-login::after {
            content: '';
            position: absolute;
            top: -50%;
            left: -50%;
            width: 200%;
            height: 200%;
            background: radial-gradient(circle, rgba(255, 255, 255, 0.3) 0%, transparent 60%);
            opacity: 0;
            transition: opacity 0.3s ease;
            pointer-events: none;
        }

        .btn-login:hover::after {
            opacity: 1;
        }

        .alert-error {
            background: rgba(255, 65, 108, 0.15);
            border: 1px solid var(--accent-red);
            color: white;
            border-radius: 12px;
            font-size: 0.85rem;
            padding: 12px;
            margin-bottom: 1.5rem;
        }
    </style>
</head>

<body>
    <div class="login-container">
        <div class="glass-card text-center">
            <div class="brand-logo">
                <i class="fa-solid fa-shield-virus"></i>
            </div>

            <h3 class="fw-bold mb-1">HEMOVAULT</h3>
            <p class="small text-muted mb-4 text-uppercase ls-2">PRESERVING THE FLOW OF LIFE</p>

            <% if (error) { %>
                <div class="alert-error">
                    <i class="fa-solid fa-circle-exclamation me-2"></i>
                    <%= error %>
                </div>
                <% } %>

                    <form action="/login" method="POST">
                        <div class="mb-4 text-start">
                            <label class="form-label">System Identity</label>
                            <input type="text" name="username" class="form-control" placeholder="USERNAME" required
                                autofocus>
                        </div>
                        <div class="mb-4 text-start">
                            <label class="form-label">Encryption Key</label>
                            <input type="password" name="password" class="form-control" placeholder="PASSWORD" required>
                        </div>
                        <button type="submit" class="btn-login">AUTHORIZE ACCESS</button>
                    </form>

                    <div class="mt-4 pt-2">
                        <small class="text-white-50">Authorized Person Only</small>
                    </div>
        </div>
    </div>
</body>

</html>