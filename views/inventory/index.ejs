<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-5 fade-in">
    <h3 class="fw-bold text-white">Inventory Integrity</h3>
    <a href="/inventory/update" class="btn-premium text-decoration-none" style="background: linear-gradient(135deg, #f6d365, #fda085);">
        <i class="fa-solid fa-pen-to-square me-2"></i>Adjust Stock Indices
    </a>
</div>

<% if (success) { %>
    <div class="alert glass border-0 bg-success bg-opacity-10 text-success fade-in mb-4">
        <i class="fa-solid fa-circle-check me-2"></i><%= success %>
    </div>
<% } %>

<div class="row fade-in" style="animation-delay: 0.2s;">
    <% inventory.forEach(inv => { 
        let color = 'var(--accent-green)';
        let glow = 'var(--accent-green)44';
        if (inv.units < 20) { color = 'var(--accent-red)'; glow = 'var(--accent-red)44'; }
        else if (inv.units <= 50) { color = 'var(--accent-purple)'; glow = 'var(--accent-purple)44'; }
    %>
    <div class="col-md-3 mb-4">
        <div class="glass p-4 text-center" style="border-top: 4px solid <%= color %>;">
            <div class="icon-wrapper glass mx-auto mb-3" style="width: 70px; height: 70px; font-size: 2rem; color: <%= color %>; background: rgba(255,255,255,0.02);">
                <i class="fa-solid fa-droplet"></i>
            </div>
            <h2 class="fw-bold fs-1 mb-1" style="color: <%= color %>; text-shadow: 0 0 10px <%= glow %>;"><%= inv.blood_group %></h2>
            <div class="text-white-50 small fw-bold mt-2">AVAILABILITY: <%= inv.units %> UNITS</div>
            
            <div class="progress-track mt-3" style="height: 4px;">
                <div class="progress-fill" style="width: <%= Math.min(inv.units, 100) %>%; background: <%= color %>; box-shadow: 0 0 8px <%= color %>;"></div>
            </div>

            <% if(inv.units < 5) { %>
                <div class="mt-3">
                    <span class="badge bg-danger rounded-pill px-3 py-1 animate-pulse" style="font-size: 0.7rem;">CRITICAL DEPLETION</span>
                </div>
            <% } %>
        </div>
    </div>
    <% }) %>
</div>

<%- include('../partials/footer') %>
