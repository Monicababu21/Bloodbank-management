<%- include('../partials/header') %>

<div class="d-flex justify-content-between align-items-center mb-4 fade-in">
    <h3 class="fw-bold text-white">Donor Registry</h3>
    <a href="/donors/add" class="btn-premium text-decoration-none">
        <i class="fa-solid fa-plus me-2"></i>Provision New Donor
    </a>
</div>

<% if (success) { %>
    <div class="alert glass border-0 bg-success bg-opacity-10 text-success fade-in mb-4">
        <i class="fa-solid fa-circle-check me-2"></i><%= success %>
    </div>
<% } %>

<div class="glass p-1 fade-in" style="animation-delay: 0.2s;">
    <div class="table-container">
        <table class="custom-table">
            <thead>
                <tr>
                    <th>NAME / IDENTITY</th>
                    <th>BLOOD GROUP</th>
                    <th>CONTACT</th>
                    <th>LAST ACTIVITY</th>
                    <th>STATUS ADVISORY</th>
                </tr>
            </thead>
            <tbody>
                <% donors.forEach(donor => { 
                    let isEligible = true;
                    let daysLeft = 0;
                    if(donor.last_donation_date) {
                        const diffDays = Math.ceil((new Date() - new Date(donor.last_donation_date)) / (1000 * 60 * 60 * 24));
                        if(diffDays < 90 && diffDays >= 0) {
                            isEligible = false;
                            daysLeft = 90 - diffDays;
                        }
                    }
                %>
                <tr>
                    <td class="fw-bold text-white"><%= donor.name %></td>
                    <td>
                        <span class="badge glass border-0" style="background: rgba(255, 65, 108, 0.1); color: var(--accent-red); padding: 8px 12px; font-weight: 600;">
                            <%= donor.blood_group %>
                        </span>
                    </td>
                    <td class="text-white-50"><%= donor.phone %></td>
                    <td><%= donor.last_donation_date ? new Date(donor.last_donation_date).toLocaleDateString() : 'NO HISTORY' %></td>
                    <td>
                        <% if (isEligible) { %>
                            <span class="badge border-0 bg-success bg-opacity-10 text-success px-3 py-2 rounded-pill">
                                <i class="fa-solid fa-check-circle me-1"></i> ELIGIBLE
                            </span>
                        <% } else { %>
                            <span class="badge border-0 bg-warning bg-opacity-10 text-warning px-3 py-2 rounded-pill" title="Can donate in <%= daysLeft %> days">
                                <i class="fa-solid fa-clock me-1"></i> WAIT: <%= daysLeft %>D LEFT
                            </span>
                        <% } %>
                    </td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>
</div>

<%- include('../partials/footer') %>
